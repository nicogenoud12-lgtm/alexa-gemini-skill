# --- Gemini (Google AI Studio) ---
# Obtené tu API key en https://aistudio.google.com/apikey (free tier, sin billing)
GEMINI_API_KEY=

# Modelo a usar. gemini-2.5-flash es free tier.
# Cuando se apague (programado 16-oct-2026) cambiá a gemini-3.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Timeout (segundos) para la llamada a Gemini antes de devolver fallback de voz.
GEMINI_TIMEOUT_SECONDS=8

# --- Alexa ---
# applicationId de tu skill (developer.amazon.com > tu skill > Endpoint / View Skill ID).
# Ej: amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Si lo dejás vacío, NO se valida el applicationId (no recomendado en producción).
ALEXA_SKILL_ID=

# Verificación de firma de Alexa (cert chain + firma + timestamp).
# true en producción (OBLIGATORIO o Amazon rechaza). false sólo para tests locales con curl.
VERIFY_ALEXA_SIGNATURE=true

# Cuántos turnos de conversación recordar en la sesión (multi-turno).
MAX_HISTORY_TURNS=5
